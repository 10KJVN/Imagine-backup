{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "2dfad4f1d6494fc28665388d15816d74",
    "m_Title": "DRAWBACKS",
    "m_Content": "- You cannot go crazy with outline thickness. Be mindful of max thickness threshold. \n\n- This technique is expensive, because we're sampling full screen textures, multiple times.\n17 times in total..\n\n- This approach doesn't work with transparant objects either\n\n- You can't omit objects with this approach, it's full screen if you wish to do so -> look into Per Object approach. Inverted Hull.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 280.0,
        "y": 505.0,
        "width": 256.0,
        "height": 217.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

